# ── Shared credentials (used for IMAP, SMTP, and CalDAV) ──────────────────────
MAIL_USER=your@email.com
MAIL_PASSWORD=your-password

# ── IMAP (incoming mail) ───────────────────────────────────────────────────────
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USE_SSL=true

# ── SMTP (outgoing mail) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_TLS=true

# ── CalDAV (calendar) ──────────────────────────────────────────────────────────
CALDAV_URL=https://caldav.example.com/dav/your%40email.com/

# ── Optional: override credentials per service ────────────────────────────────
# IMAP_USER=
# IMAP_PASSWORD=
# SMTP_USER=
# SMTP_PASSWORD=
# CALDAV_USER=
# CALDAV_PASSWORD=
